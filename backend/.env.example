# Copiar este archivo como backend/.env y completar los valores locales.
# No subir backend/.env a git ni compartirlo.

# Correo de prueba para leer facturas por IMAP.
INVOICES_EMAIL_ADDRESS="facturas@tu-dominio.com"
INVOICES_EMAIL_HOST="imap.gmail.com"
INVOICES_EMAIL_USERNAME="facturas@tu-dominio.com"
INVOICES_EMAIL_SECRET_ENV_VAR="FACTURAS_EMAIL_PASSWORD"
INVOICES_EMAIL_FOLDER="INBOX"

# App-password de Gmail. No pegar esta clave en la app.
# En la pantalla Facturas, el campo "Variable de clave" debe decir FACTURAS_EMAIL_PASSWORD.
FACTURAS_EMAIL_PASSWORD="pegar-aca-la-app-password-de-google"
